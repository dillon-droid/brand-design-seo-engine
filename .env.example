# Neon Postgres connection string
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Google Gemini API (free tier — get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Auth
AUTH_SECRET=replace-with-32-byte-random-hex

# Google Search Console (service account JSON, base64-encoded)
GOOGLE_SA_KEY_B64=

# Neon Postgres connection string
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Google Gemini API (free tier — get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Auth
AUTH_SECRET=replace-with-32-byte-random-hex

# Google OAuth (per-user) — get from console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# (Legacy) Google service account — no longer used; OAuth replaces this
# GOOGLE_SA_KEY_B64=

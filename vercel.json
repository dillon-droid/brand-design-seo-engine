{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/rankings", "schedule": "0 6 * * *" },
    { "path": "/api/cron/process-articles", "schedule": "*/15 * * * *" }
  ]
}
